# WispChat Configuration Template
# Copy this file to .env and fill in with secure values
# Generate secure keys using: python -c "import secrets; print(secrets.token_hex(32))"

# Application Settings
APP_ENV=production
DEBUG=false
HOST=0.0.0.0
PORT=8000

# Security - CRITICAL: Never use default values in production!
# Generate SECRET_KEY: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here-change-in-production

# Generate ENCRYPTION_KEY: python -c "import secrets; print(secrets.token_hex(32))"
# Must be 32 bytes (64 hex characters) for AES-256
ENCRYPTION_KEY=your-encryption-key-here-32-bytes-hex

# JWT Settings
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_WS_CONNECTIONS_PER_IP=10

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/wispchat.db
